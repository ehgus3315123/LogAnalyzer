<Window x:Class="LogAnalyzer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LogAnalyzer"
        Title="Log Analyzer" Height="860" Width="1280" MinWidth="900" MinHeight="600"
        Icon="pack://application:,,,/App.ico"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="Segoe UI" FontSize="13"
        AllowDrop="True"
        PreviewDragOver="MainWindow_PreviewDragOver"
        DragLeave="MainWindow_DragLeave"
        Drop="MainWindow_Drop">

    <Window.Resources>
        <local:LevelToBrushConverter x:Key="LevelToBrush"/>
        <local:LevelToBackgroundConverter x:Key="LevelToBg"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <local:StringNotEmptyToVisibilityConverter x:Key="StrNotEmptyToVis"/>
        <local:NullToVisibilityConverter x:Key="NullToVis"/>
        <local:IntGreaterThanZeroToVisibilityConverter x:Key="IntGtZeroToVis"/>
        <local:DoubleToPercentStringConverter x:Key="DoubleToPercent"/>
        <local:PercentToWidthConverter x:Key="PercentToWidth"/>
        <local:DragOverBrushConverter x:Key="DragOverBrush"/>

        <!-- Button Style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- TextBox Style -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox Style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- DatePicker Style -->
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>

        <!-- ListView / GridView style -->
        <Style x:Key="LogListView" TargetType="ListView">
            <Setter Property="FontFamily" Value="맑은 고딕"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
            <Setter Property="VirtualizingStackPanel.IsVirtualizing" Value="True"/>
            <Setter Property="VirtualizingStackPanel.VirtualizationMode" Value="Recycling"/>
            <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True"/>
        </Style>

        <Style x:Key="LogListViewItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBrush}"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- GridViewColumnHeader style -->
        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <!-- Card Border Style -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="12"/>
        </Style>

        <!-- Section header -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>

        </Style>

    </Window.Resources>

    <Window.InputBindings>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{Binding}" CommandParameter="FocusSearch"
                    x:Name="FocusSearchBinding"/>
        <KeyBinding Key="E" Modifiers="Ctrl" Command="{Binding ErrorOnlyCommand}"/>

        <KeyBinding Key="F" Modifiers="Ctrl+Shift" Command="{x:Static local:MainWindow.OpenLogSearchCommand}"/>
    </Window.InputBindings>

    <Grid>
        <!-- Startup mode selection -->
        <Border Background="{DynamicResource BackgroundBrush}"
                Visibility="{Binding IsStartupScreenVisible, Converter={StaticResource BoolToVis}}">
            <Grid>
                <!-- Main card -->
                <Border Style="{StaticResource Card}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Padding="20"
                        Width="900"
                        MaxWidth="900">
                    <StackPanel>
                        <TextBlock Text="분석 모드 선택" FontSize="24" FontWeight="Bold" Margin="0,0,0,6"/>
                        <TextBlock Foreground="{DynamicResource ForegroundMutedBrush}" Margin="0,0,0,16">
                            <Run Text="먼저 단일 파일 분석 또는 다중 파일 비교 모드를 선택하세요.  "/>
                            <Run Text="또는 .log / .txt 파일을 이 창에 바로 드래그하세요." FontStyle="Italic"/>
                        </TextBlock>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Single file card -->
                            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="📄  단일 파일 분석" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="하나의 로그 파일을 로드해 분석합니다."
                                               Foreground="{DynamicResource ForegroundMutedBrush}"
                                               Margin="0,0,0,10"/>
                                    <Button Content="단일 파일 선택 후 시작"
                                            Style="{StaticResource PrimaryButton}"
                                            HorizontalAlignment="Left"
                                            Command="{Binding SelectSingleModeCommand}"/>
                                </StackPanel>
                            </Border>

                            <!-- Compare card -->
                            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="🔀  다중 파일 비교" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="두 개 이상의 로그 파일을 함께 로드해 비교합니다."
                                               Foreground="{DynamicResource ForegroundMutedBrush}"
                                               Margin="0,0,0,10"/>
                                    <Button Content="다중 파일 비교 모드 선택"
                                            Style="{StaticResource SecondaryButton}"
                                            HorizontalAlignment="Left"
                                            Command="{Binding SelectCompareModeCommand}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Drag hint strip -->
                        <Border CornerRadius="6" Padding="16,14" BorderThickness="2">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Style.Triggers>
                                        <!-- valid drop -->
                                        <DataTrigger Binding="{Binding IsDragOverValid}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="Background" Value="#140D47A1"/>
                                        </DataTrigger>
                                        <!-- invalid drop (IsDragOver=true, IsDragOverValid=false) -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding IsDragOver}" Value="True"/>
                                                <Condition Binding="{Binding IsDragOverValid}" Value="False"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="BorderBrush" Value="Crimson"/>
                                            <Setter Property="Background" Value="#10DC143C"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <!-- State 1: not dragging -->
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDragOver}" Value="True">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="📂" FontSize="20" VerticalAlignment="Center"
                                               Margin="0,0,10,0" Opacity="0.5"/>
                                    <TextBlock Text=".log / .txt 파일을 이 창에 드래그하면 바로 분석을 시작합니다"
                                               Foreground="{DynamicResource ForegroundMutedBrush}"
                                               FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- State 2: valid drop -->
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsDragOverValid}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="✅" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="파일을 놓으면 단일 파일 분석을 시작합니다"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>

                                <!-- State 3: invalid drop -->
                                <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                                    <StackPanel.Style>
                                        <Style TargetType="StackPanel">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding IsDragOver}" Value="True"/>
                                                        <Condition Binding="{Binding IsDragOverValid}" Value="False"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </StackPanel.Style>
                                    <TextBlock Text="⛔" FontSize="24" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text=".log 또는 .txt 파일 1개만 드롭할 수 있습니다"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="Crimson" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Compare setup panel -->
                        <Border Style="{StaticResource Card}" Margin="0,12,0,0"
                                Visibility="{Binding IsCompareSetupVisible, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <TextBlock Text="파일 비교 가져오기" Style="{StaticResource SectionHeader}"/>

                                <TextBlock Text="첫 번째 파일" FontSize="11" Foreground="{DynamicResource ForegroundMutedBrush}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Style="{StaticResource SearchBox}"
                                             IsReadOnly="True"
                                             Text="{Binding CompareFirstFilePath, Mode=OneWay}"
                                             Margin="0,0,8,0"/>
                                    <Button Grid.Column="1"
                                            Content="찾아보기..."
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding BrowseCompareFirstFileCommand}"/>
                                </Grid>

                                <TextBlock Text="두 번째 파일" FontSize="11" Foreground="{DynamicResource ForegroundMutedBrush}" Margin="0,0,0,4"/>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0"
                                             Style="{StaticResource SearchBox}"
                                             IsReadOnly="True"
                                             Text="{Binding CompareSecondFilePath, Mode=OneWay}"
                                             Margin="0,0,8,0"/>
                                    <Button Grid.Column="1"
                                            Content="찾아보기..."
                                            Style="{StaticResource SecondaryButton}"
                                            Command="{Binding BrowseCompareSecondFileCommand}"/>
                                </Grid>

                                <Button Content="비교 시작"
                                        Style="{StaticResource PrimaryButton}"
                                        HorizontalAlignment="Left"
                                        Command="{Binding StartCompareModeCommand}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Full-window drag overlay (appears on top when dragging over startup screen) -->
                <Border x:Name="DragOverlay"
                        Visibility="{Binding IsDragOver, Converter={StaticResource BoolToVis}}"
                        IsHitTestVisible="False">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="Transparent"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDragOverValid}" Value="True">
                                    <Setter Property="Background" Value="#0F0D47A1"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>

                    <!-- Animated border ring -->
                    <Border HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                            BorderThickness="3" CornerRadius="0" Margin="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="Crimson"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDragOverValid}" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                    </Border>
                </Border>
            </Grid>
        </Border>

        <Grid Visibility="{Binding IsStartupScreenVisible, Converter={StaticResource InvBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>  <!-- Toolbar -->
                <RowDefinition Height="*"/>     <!-- Main Content -->
                <RowDefinition Height="Auto"/>  <!-- Status Bar -->
            </Grid.RowDefinitions>

        <!-- ══ TOOLBAR ══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Title + load buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="📋 Log Analyzer" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource ForegroundBrush}" VerticalAlignment="Center"
                               Margin="0,0,20,0"/>
                    <Button Content="⏮ 처음으로" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ResetToStartupCommand}" Margin="0,0,8,0"
                            ToolTip="모드 선택 화면으로 돌아가기"/>
                    <Button Content="🔎 로그 검색  (Ctrl+Shift+F)" Style="{StaticResource SecondaryButton}"
                            Click="OpenSearch_Click"
                            ToolTip="로드된 전체 로그에서 찾기 (제외 조건과 무관)"/>
                    <!-- Loaded file count badge -->
                    <Border Background="{DynamicResource AccentBrush}" CornerRadius="10"
                            Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                            Visibility="{Binding LoadedFiles.Count, Converter={StaticResource IntGtZeroToVis}}">
                        <TextBlock Foreground="White" FontSize="11" FontWeight="Bold">
                            <Run Text="{Binding LoadedFiles.Count, Mode=OneWay}"/>
                            <Run Text="개 파일"/>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Right: Theme toggle + export -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="💾 CSV (전체)" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportCsvCommand}" Margin="0,0,6,0"
                            ToolTip="현재 표시 목록 전체를 CSV로 저장 (제외 반영)"/>
                    <Button Content="💾 TXT (전체)" Style="{StaticResource SecondaryButton}"
                            Command="{Binding ExportTxtCommand}" Margin="0,0,8,0"
                            ToolTip="현재 표시 목록 전체를 원문 줄 TXT로 저장 (제외 반영)"/>
                    <Button x:Name="ExportSelectedCsvButton" Content="💾 선택 CSV" IsEnabled="False"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,6,0"
                            Click="ExportSelectedCsv_Click"
                            ToolTip="목록에서 선택한 줄만 CSV로 저장 (Ctrl·Shift로 다중 선택)"/>
                    <Button x:Name="ExportSelectedTxtButton" Content="💾 선택 TXT" IsEnabled="False"
                            Style="{StaticResource SecondaryButton}" Margin="0,0,12,0"
                            Click="ExportSelectedTxt_Click"
                            ToolTip="목록에서 선택한 줄만 원문 TXT로 저장 (Ctrl·Shift로 다중 선택)"/>
                    <Button Style="{StaticResource SecondaryButton}"
                            Command="{Binding ToggleDarkModeCommand}" Padding="10,6">
                        <Grid Width="18">
                            <TextBlock Text="🌙" HorizontalAlignment="Center"
                                       Visibility="{Binding IsDarkMode, Converter={StaticResource InvBoolToVis}}"/>
                            <TextBlock Text="☀" HorizontalAlignment="Center"
                                       Visibility="{Binding IsDarkMode, Converter={StaticResource BoolToVis}}"/>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══ MAIN CONTENT ═════════════════════════════════════════════ -->
        <Grid Grid.Row="1" Margin="12,10,12,8">

            <!-- ── Log list ──────────────────────────────────────────── -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- Log list -->
                    <RowDefinition Height="Auto"/> <!-- Detail pane -->
                </Grid.RowDefinitions>

                <!-- Log list -->
                <Border Grid.Row="0" Style="{StaticResource Card}" Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- List header bar -->
                        <Border Grid.Row="0" Background="{DynamicResource SurfaceAltBrush}"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                Padding="12,7" CornerRadius="6,6,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋  로그 목록" FontWeight="Bold"
                                                   Foreground="{DynamicResource ForegroundBrush}"/>
                                        <Border Background="{DynamicResource AccentBrush}" CornerRadius="8"
                                                Padding="7,2" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock FontSize="11" FontWeight="Bold" Foreground="White">
                                                <Run Text="{Binding FilteredCount, Mode=OneWay}"/>
                                                <Run Text="건"/>
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="Ctrl+F 키워드 검색  |  Ctrl+Shift+F 전문 검색  |  Ctrl+O 열기  |  목록: Ctrl/Shift 다중 선택 후 상단 «선택 CSV/TXT»"
                                               HorizontalAlignment="Right" FontSize="11"
                                               Foreground="{DynamicResource ForegroundMutedBrush}"
                                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                </Grid>

                                <!-- FilterChip 칩 목록 -->
                                <ItemsControl ItemsSource="{Binding FilterChips}"
                                              Visibility="{Binding FilterChips.Count, Converter={StaticResource IntGtZeroToVis}}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource AccentBrush}"
                                                    CornerRadius="10" Margin="0,0,4,4" Padding="8,2">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Keyword}"
                                                               Foreground="White" FontSize="11"
                                                               VerticalAlignment="Center"/>
                                                    <Button Content="×"
                                                            Command="{Binding RemoveCommand}"
                                                            Background="Transparent" BorderThickness="0"
                                                            Foreground="White" FontSize="13"
                                                            Padding="4,0,0,0" Cursor="Hand"
                                                            VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- 키워드 입력 + 추가 버튼 -->
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Content="+"
                                            Command="{Binding AddFilterChipCommand}"
                                            Style="{StaticResource SecondaryButton}"
                                            Padding="10,3" Margin="6,0,0,0" FontSize="14" FontWeight="Bold"
                                            ToolTip="키워드를 필터 칩으로 추가 (Enter)"/>
                                    <TextBox x:Name="FilterChipSearchBox"
                                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SearchBox}"
                                             Tag="포함 키워드 검색 (Enter 또는 + 로 칩 추가)"
                                             ToolTip="메시지 또는 소스에 포함된 항목만 표시. Enter 또는 + 버튼으로 칩 추가"
                                             KeyDown="FilterChipSearchBox_KeyDown"/>
                                </DockPanel>
                            </StackPanel>
                        </Border>

                        <!-- Loading overlay -->
                        <Grid Grid.Row="1">
                            <ListView x:Name="LogListView"
                                      Style="{StaticResource LogListView}"
                                      ItemContainerStyle="{StaticResource LogListViewItem}"
                                      ItemsSource="{Binding FilteredView}"
                                      SelectedItem="{Binding SelectedEntry}"
                                      SelectionMode="Extended"
                                      SelectionChanged="AnyLogList_SelectionChanged"
                                      BorderThickness="0,0,0,0"
                                      Visibility="{Binding IsSingleMode, Converter={StaticResource BoolToVis}}">
                                <ListView.View>
                                    <GridView>
                                        <GridViewColumn Header="#" Width="55">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding LineNumber}"
                                                               Foreground="{DynamicResource ForegroundMutedBrush}"
                                                               FontSize="11" Padding="4,3"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="시각" Width="150">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding TimestampDisplay}"
                                                               Foreground="{DynamicResource ForegroundMutedBrush}"
                                                               FontFamily="맑은 고딕" FontSize="12" Padding="4,3"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="레벨" Width="66">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Border CornerRadius="3" Margin="2"
                                                            Background="{Binding LevelDisplay, Converter={StaticResource LevelToBg}}"
                                                            Padding="5,2">
                                                        <TextBlock Text="{Binding LevelDisplay}"
                                                                   Foreground="{Binding LevelDisplay, Converter={StaticResource LevelToBrush}}"
                                                                   FontWeight="Bold" FontSize="11"
                                                                   HorizontalAlignment="Center"/>
                                                    </Border>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="소스" Width="120">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Source}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               FontSize="11" Padding="4,3"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="파일" Width="110">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding FileName}"
                                                               Foreground="{DynamicResource ForegroundMutedBrush}"
                                                               FontSize="11" Padding="4,3"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                        <GridViewColumn Header="메시지" Width="900">
                                            <GridViewColumn.CellTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Message}"
                                                               FontFamily="맑은 고딕" FontSize="12"
                                                               Foreground="{DynamicResource ForegroundBrush}"
                                                               TextTrimming="CharacterEllipsis" Padding="4,3"
                                                               ToolTip="{Binding RawLine}"/>
                                                </DataTemplate>
                                            </GridViewColumn.CellTemplate>
                                        </GridViewColumn>
                                    </GridView>
                                </ListView.View>
                            </ListView>

                            <Grid Visibility="{Binding IsCompareMode, Converter={StaticResource BoolToVis}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="6"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="{DynamicResource SurfaceAltBrush}" Padding="8,5">
                                            <TextBlock FontWeight="Bold">
                                                <Run Text="1번 파일: "/>
                                                <Run Text="{Binding CompareFirstFileName, Mode=OneWay}"/>
                                                <Run Text="  ("/>
                                                <Run Text="{Binding CompareFirstCount, Mode=OneWay}"/>
                                                <Run Text="건)"/>
                                            </TextBlock>
                                        </Border>
                                        <ListView x:Name="CompareFirstListView"
                                                  Grid.Row="1"
                                                  Style="{StaticResource LogListView}"
                                                  ItemContainerStyle="{StaticResource LogListViewItem}"
                                                  ItemsSource="{Binding CompareFirstView}"
                                                  SelectedItem="{Binding SelectedEntry}"
                                                  SelectionMode="Extended"
                                                  SelectionChanged="AnyLogList_SelectionChanged"
                                                  BorderThickness="0">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="시각" Width="90" DisplayMemberBinding="{Binding TimestampDisplay}"/>
                                                    <GridViewColumn Header="레벨" Width="66">
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="3" Margin="2"
                                                                        Background="{Binding LevelDisplay, Converter={StaticResource LevelToBg}}"
                                                                        Padding="5,2">
                                                                    <TextBlock Text="{Binding LevelDisplay}"
                                                                               Foreground="{Binding LevelDisplay, Converter={StaticResource LevelToBrush}}"
                                                                               FontWeight="Bold" FontSize="11"
                                                                               HorizontalAlignment="Center"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                    <GridViewColumn Header="소스" Width="110" DisplayMemberBinding="{Binding Source}"/>
                                                    <GridViewColumn Header="메시지" Width="500" DisplayMemberBinding="{Binding Message}"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="2">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" Background="{DynamicResource SurfaceAltBrush}" Padding="8,5">
                                            <TextBlock FontWeight="Bold">
                                                <Run Text="2번 파일: "/>
                                                <Run Text="{Binding CompareSecondFileName, Mode=OneWay}"/>
                                                <Run Text="  ("/>
                                                <Run Text="{Binding CompareSecondCount, Mode=OneWay}"/>
                                                <Run Text="건)"/>
                                            </TextBlock>
                                        </Border>
                                        <ListView x:Name="CompareSecondListView"
                                                  Grid.Row="1"
                                                  Style="{StaticResource LogListView}"
                                                  ItemContainerStyle="{StaticResource LogListViewItem}"
                                                  ItemsSource="{Binding CompareSecondView}"
                                                  SelectedItem="{Binding SelectedEntry}"
                                                  SelectionMode="Extended"
                                                  SelectionChanged="AnyLogList_SelectionChanged"
                                                  BorderThickness="0">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="시각" Width="90" DisplayMemberBinding="{Binding TimestampDisplay}"/>
                                                    <GridViewColumn Header="레벨" Width="66">
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <Border CornerRadius="3" Margin="2"
                                                                        Background="{Binding LevelDisplay, Converter={StaticResource LevelToBg}}"
                                                                        Padding="5,2">
                                                                    <TextBlock Text="{Binding LevelDisplay}"
                                                                               Foreground="{Binding LevelDisplay, Converter={StaticResource LevelToBrush}}"
                                                                               FontWeight="Bold" FontSize="11"
                                                                               HorizontalAlignment="Center"/>
                                                                </Border>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                    <GridViewColumn Header="소스" Width="110" DisplayMemberBinding="{Binding Source}"/>
                                                    <GridViewColumn Header="메시지" Width="500" DisplayMemberBinding="{Binding Message}"/>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </Grid>
                                </Border>
                            </Grid>

                            <!-- Empty state -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="📂" FontSize="48" HorizontalAlignment="Center"
                                           Opacity="0.3" Margin="0,0,0,12"/>
                                <TextBlock Text="로그 파일을 추가하거나 제외 조건을 조정하세요"
                                           FontSize="15" Foreground="{DynamicResource ForegroundMutedBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Loading indicator -->
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                                <TextBlock FontSize="14" Foreground="{DynamicResource AccentBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,10">
                                    <Run Text="⟳ 로딩 중...  "/>
                                    <Run Text="{Binding LoadProgress, Mode=OneWay}"/>
                                    <Run Text="%"/>
                                </TextBlock>
                                <ProgressBar Value="{Binding LoadProgress, Mode=OneWay}" Maximum="100" Height="6"
                                             Width="300" Foreground="{DynamicResource AccentBrush}"
                                             Background="{DynamicResource SurfaceAltBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Detail pane for selected entry -->
                <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,8,0,0"
                        MaxHeight="120"
                        Visibility="{Binding SelectedEntry, Converter={StaticResource NullToVis}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Style="{StaticResource SectionHeader}">
                            <Run Text="📄  "/>
                            <Run Text="{Binding SelectedEntry.TimestampDisplay, Mode=OneWay}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding SelectedEntry.LevelDisplay, Mode=OneWay}"
                                 Foreground="{DynamicResource ErrorBrush}"/>
                            <Run Text="  "/>
                            <Run Text="{Binding SelectedEntry.Source, Mode=OneWay}"/>
                        </TextBlock>
                        <StackPanel Grid.Row="1">
                            <TextBox Text="{Binding SelectedEntry.Message, Mode=OneWay}"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource ForegroundBrush}"
                                     FontFamily="맑은 고딕" FontSize="12" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding SelectedEntry.CallStack, Mode=OneWay}"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="{DynamicResource ForegroundMutedBrush}"
                                     FontFamily="맑은 고딕" FontSize="11"
                                     Visibility="{Binding SelectedEntry.CallStack, Converter={StaticResource StrNotEmptyToVis}}"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </Grid>
        </Grid>

        <!-- ══ STATUS BAR ════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="12,5">
            <Grid>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource ForegroundMutedBrush}" FontSize="12"/>
                <TextBlock HorizontalAlignment="Right"
                           Foreground="{DynamicResource ForegroundMutedBrush}" FontSize="12">
                    <Run Text="전체 "/>
                    <Run Text="{Binding TotalCount, Mode=OneWay}"/>
                    <Run Text=" 줄"/>
                </TextBlock>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
