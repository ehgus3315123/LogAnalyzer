<Window x:Class="LogAnalyzer.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LogAnalyzer"
        Title="로그 검색" Height="560" Width="720" MinHeight="360" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="Segoe UI" FontSize="13"
        Icon="pack://application:,,,/App.ico"
        Loaded="SearchWindow_OnLoaded">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="GridViewColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <local:StringNotEmptyToVisibilityConverter x:Key="StrNotEmptyToVis"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="원문 줄(Raw line)에서 검색합니다. 제외 조건과 무관하게 로드된 전체 로그를 대상으로 합니다."
                   FontSize="11" Foreground="{DynamicResource ForegroundMutedBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="QueryBox" Grid.Column="0" Style="{StaticResource SearchBox}"
                         Text="{Binding Query, UpdateSourceTrigger=PropertyChanged}"
                         KeyDown="QueryBox_OnKeyDown"/>
                <CheckBox Grid.Column="1" Content="정규식" IsChecked="{Binding UseRegex}"
                          VerticalAlignment="Center" Margin="12,0,0,0"/>
                <Button Grid.Column="2" Content="검색" Style="{StaticResource PrimaryButton}"
                        Command="{Binding SearchCommand}" IsDefault="True" Margin="12,0,0,0"/>
                <Button Grid.Column="3" Content="이동" Style="{StaticResource SecondaryButton}"
                        Command="{Binding GoToCommand}" Margin="8,0,0,0"
                        ToolTip="목록에서 해당 줄을 선택합니다 (더블클릭과 동일)"/>
            </Grid>
            <TextBlock Grid.Row="1" Text="{Binding RegexError}" Foreground="{DynamicResource ErrorBrush}"
                       FontSize="11"
                       Visibility="{Binding RegexError, Converter={StaticResource StrNotEmptyToVis}}"/>
        </Grid>

        <Border Grid.Row="2" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="4" Margin="0,0,0,12">
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                        Padding="10,6" CornerRadius="4,4,0,0">
                    <TextBlock Text="{Binding ResultSummary}" FontWeight="SemiBold"/>
                </Border>
                <ListView x:Name="ResultsList"
                          ItemsSource="{Binding Results}"
                          SelectedItem="{Binding SelectedResult}"
                          FontFamily="맑은 고딕"
                          Background="{DynamicResource SurfaceBrush}"
                          Foreground="{DynamicResource ForegroundBrush}"
                          BorderThickness="0"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling"
                          MouseDoubleClick="ResultsList_OnMouseDoubleClick">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="#" Width="52">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LineNumber}" FontSize="11"
                                                   Foreground="{DynamicResource ForegroundMutedBrush}" Padding="4,2"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="시각" Width="145">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding TimestampDisplay}" FontFamily="맑은 고딕" FontSize="11"
                                                   Padding="4,2"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="레벨" Width="72">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LevelDisplay}" FontWeight="Bold" Padding="4,2"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="메시지" Width="320">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Message}" FontFamily="맑은 고딕" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" Padding="4,2"
                                                   ToolTip="{Binding RawLine}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="파일" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding FileName}" FontSize="11"
                                                   TextTrimming="CharacterEllipsis" Padding="4,2"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="닫기" Style="{StaticResource SecondaryButton}" IsCancel="True"
                    Click="Close_OnClick"/>
        </StackPanel>
    </Grid>
</Window>
